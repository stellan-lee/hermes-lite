# Marlow Lite secrets example
# Copy only the entries you use to ~/.marlow/.env.

# Custom/local compatible model endpoint (referenced from config.yaml).
CUSTOM_API_KEY=

# Retained gateway connectors.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_ALLOWED_USERS=
WEBHOOK_SECRET=

# Web search.
BRAVE_SEARCH_API_KEY=

# Optional retained memory provider.
HONCHO_API_KEY=
HONCHO_BASE_URL=

# Retained speech backends.
VOICE_TOOLS_OPENAI_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
ELEVENLABS_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
GEMINI_API_KEY=

# Optional LM Studio bearer token.
LM_API_KEY=
LM_BASE_URL=http://127.0.0.1:1234/v1
