inference:
  model: your-model
  base_url: ""
  api_key_env: OPENAI_API_KEY
  temperature: 0.2
agent:
  max_iterations: 20
  system_prompt: ""
tools:
  enabled:
    - read_file
    - write_file
    - patch
    - search_files
    - terminal
  workspace: .
  terminal:
    enabled: true
    confirm: true
    timeout_seconds: 60
sessions:
  enabled: true
  resume_latest: false
logging:
  level: WARNING
  file: true
