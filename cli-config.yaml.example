# Marlow Lite configuration example
# Copy to ~/.marlow/config.yaml. Secrets may use ${ENV_VAR} references and
# should live in ~/.marlow/.env.

model:
  # Codex is the default retained hosted runtime. Run `marlow auth` first.
  provider: openai-codex
  default: gpt-5.4

  # For an OpenAI-compatible local/custom endpoint, use instead:
  # provider: custom
  # default: your-model-id
  # base_url: http://127.0.0.1:1234/v1
  # api_key: ${CUSTOM_API_KEY}
  # api_mode: chat_completions

# Named compatible endpoints are optional. They work with Ollama, vLLM,
# LM Studio, llama.cpp, and compatible remote services.
providers: {}
# providers:
#   local-vllm:
#     base_url: http://127.0.0.1:8000/v1
#     model: your-model-id
#     api_key: ${CUSTOM_API_KEY}
#     api_mode: chat_completions

fallback_providers: []
toolsets: [marlow-cli]

agent:
  max_turns: 90
  api_max_retries: 3
  gateway_timeout: 1800
  restart_drain_timeout: 180
  clarify_timeout: 600
  disabled_toolsets: []

terminal:
  backend: local       # local | docker | ssh
  cwd: .
  timeout: 180
  env_passthrough: []
  docker_image: nikolaik/python-nodejs:python3.11-nodejs20
  docker_volumes: []
  docker_mount_cwd_to_workspace: false

compression:
  enabled: true
  threshold: 0.50
  target_ratio: 0.20
  protect_first_n: 3
  protect_last_n: 20

auxiliary:
  vision: {provider: auto, model: "", base_url: "", api_key: "", timeout: 120}
  web_extract: {provider: auto, model: "", base_url: "", api_key: "", timeout: 360}
  compression: {provider: auto, model: "", base_url: "", api_key: "", timeout: 120}
  approval: {provider: auto, model: "", base_url: "", api_key: "", timeout: 30}
  mcp: {provider: auto, model: "", base_url: "", api_key: "", timeout: 30}
  title_generation: {provider: auto, model: "", base_url: "", api_key: "", timeout: 30}
  curator: {provider: auto, model: "", base_url: "", api_key: "", timeout: 600}

display:
  compact: false
  personality: ""
  skin: default
  language: en
  streaming: false
  show_reasoning: false
  tool_progress_command: false

memory:
  memory_enabled: true
  user_profile_enabled: true
  provider: ""         # "" | holographic | honcho

delegation:
  model: ""            # empty = inherit parent
  provider: ""
  base_url: ""
  api_key: ""
  api_mode: ""
  max_iterations: 50
  max_concurrent_children: 3
  max_async_children: 3
  max_spawn_depth: 1
  orchestrator_enabled: true

goals:
  max_turns: 20

curator:
  enabled: true
  interval_hours: 168
  min_idle_hours: 2
  stale_after_days: 30
  archive_after_days: 90

skills:
  external_dirs: []
  template_vars: true
  inline_shell: false

checkpoints:
  enabled: false
  max_snapshots: 20
  auto_prune: true

approvals:
  mode: manual
  timeout: 60
  cron_mode: deny
  mcp_reload_confirm: true
  destructive_slash_confirm: true

cron:
  wrap_response: true
  max_parallel_jobs: null

web:
  backend: ""
  search_backend: ""   # brave_free | ddgs
  extract_backend: ""  # native

browser:
  inactivity_timeout: 120
  command_timeout: 30
  cdp_url: ""

stt:
  enabled: true
  provider: local
  local: {model: base, language: ""}

tts:
  provider: edge
  edge: {voice: en-US-AriaNeural}

voice:
  record_key: ctrl+b
  max_recording_seconds: 120
  auto_tts: false

plugins:
  enabled: []

mcp_servers: {}
# mcp_servers:
#   example:
#     command: npx
#     args: ["-y", "@example/mcp-server"]
#     env: {EXAMPLE_TOKEN: "${EXAMPLE_TOKEN}"}

gateway:
  strict: false
  media_delivery_allow_dirs: []
  trust_recent_files: true

telegram:
  reactions: false
  allowed_chats: ""

discord:
  require_mention: true
  auto_thread: true
  reactions: true

slack:
  require_mention: true
  allowed_channels: ""

logging:
  level: INFO
  max_size_mb: 5
  backup_count: 3
